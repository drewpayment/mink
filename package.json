{
  "name": "@drewpayment/mink",
  "version": "0.12.0-beta.1",
  "description": "A hidden presence that moves alongside the developer — token efficiency and cross-project wiki for AI coding assistants",
  "type": "module",
  "bin": {
    "mink": "./dist/cli.node.js",
    "mink-bun": "./dist/cli.bun.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "postinstall": "bun run build 2>/dev/null || true",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun run build"
  },
  "files": [
    "src/**/*.ts",
    "dist/cli.node.js",
    "dist/cli.bun.js",
    "scripts/build.mjs",
    "skills/**/*",
    "agents/**/*",
    "dashboard/out"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewpayment/mink.git"
  },
  "license": "MIT",
  "dependencies": {
    "puppeteer-core": "^24.0.0"
  },
  "optionalDependencies": {
    "@puppeteer/browsers": "^2.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.12"
  }
}
